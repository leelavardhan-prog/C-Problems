#include <stdio.h>
int main(){
    int i, j;
    int n = 15;
    for(i = 1; i <= n; i++){
        for(j = 1; j <= n; j++){
            int min = i;
            if(j < min){
                min = j;
                }
            if(n - i + 1 < min){
                min = n - i + 1;
                }
            if(n - j + 1 < min){
                min = n - j + 1;
                }
            printf("%d", min);
        }
        printf("\n");
    }
    return 0;
}
