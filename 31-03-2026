#include <stdio.h>
int main(){
    int i, j;
    int n = 5;
    for(i = 1; i <= n; i++){
        for(j = 1; j < i; j++){
            printf(" ");
        }
        printf("*");
        for(j = 1; j <= 2*(n - i) - 1; j++){
            printf(" ");
        }
        if(i != n){
            printf("*");
        }
        printf("\n");
    }
    return 0;
}
