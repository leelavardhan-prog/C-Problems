#include <stdio.h>
#include <string.h>

int main()
{
    char s1[] = "listen";
    char s2[] = "silent";

    int count[256] = {0};

    for(int i=0;s1[i];i++)
        count[s1[i]]++;

    for(int i=0;s2[i];i++)
        count[s2[i]]--;

    int flag = 1;

    for(int i=0;i<256;i++)
    {
        if(count[i] != 0)
        {
            flag = 0;
            break;
        }
    }

    if(flag)
        printf("Anagram");
    else
        printf("Not Anagram");
}
