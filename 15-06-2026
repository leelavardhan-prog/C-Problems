int longestPalindrome(char* s) {
    int freq[128] = {0};
    
    for (int i = 0; s[i] != '\0'; i++) {
        freq[s[i]]++;
    }
    
    int length = 0;
    int oddFound = 0;
    
    for (int i = 0; i < 128; i++) {
        length += (freq[i] / 2) * 2;  // add even pairs
        
        if (freq[i] % 2 == 1) {
            oddFound = 1;
        }
    }
    
    if (oddFound) {
        length++;  // place one odd character in center
    }
    
    return length;
}
