/**
 * Definition for a binary tree node.
 * struct TreeNode {
 *     int val;
 *     struct TreeNode *left;
 *     struct TreeNode *right;
 * };
 */

int prev = -1;
int minDiff;

void inorder(struct TreeNode* root) {
    if (root == NULL) return;

    inorder(root->left);

    if (prev != -1) {
        int diff = root->val - prev;
        if (diff < minDiff)
            minDiff = diff;
    }
    prev = root->val;

    inorder(root->right);
}

int getMinimumDifference(struct TreeNode* root) {
    prev = -1;
    minDiff = 1000000;

    inorder(root);

    return minDiff;
}
