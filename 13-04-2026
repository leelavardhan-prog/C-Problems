#include <stdio.h>
void subset(int arr[], int n, int index, int temp[], int size){
    if(index == n){
        for(int i = 0; i < size; i++)
            printf("%d ", temp[i]);
        printf("\n");
        return;
    }
    temp[size] = arr[index];
    subset(arr, n, index+1, temp, size+1);
    subset(arr, n, index+1, temp, size);
}
int main(){
    int arr[] = {1,2,3};
    int temp[10];
    subset(arr, 3, 0, temp, 0);
}
