#include <stdio.h>

int main()
{
    int arr[] = {10,20,5,8,25};
    int n = 5;

    int largest = arr[0];
    int second = arr[0];

    for(int i=0;i<n;i++)
    {
        if(arr[i] > largest)
        {
            second = largest;
            largest = arr[i];
        }
        else if(arr[i] > second && arr[i] != largest)
        {
            second = arr[i];
        }
    }

    printf("Second Largest = %d", second);
}
